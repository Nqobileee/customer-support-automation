@startuml
top to bottom direction
skinparam rectangle {
  RoundCorner 10
}

title Customer Support Automation - Data Flow Diagram (Level 1)

actor "Customer" as E1
actor "Support Agent" as E2

rectangle "P1: Email Intake & Parsing" as P1
rectangle "P2: AI Triage & Enrichment" as P2
rectangle "P3: Ticket Sync (Monday.com)" as P3
rectangle "P4: Communication Manager" as P4
rectangle "P5: Orchestration & Escalation" as P5

database "D1: Messages Store" as D1
database "D2: Tickets Store" as D2
database "D3: AI Insights Store" as D3
database "D4: Audit Log Store" as D4

cloud "Monday.com API" as X1
cloud "Claude API" as X2
cloud "SMTP Service" as X3

E1 --> X3 : support email
X3 --> P1 : inbound message
P1 --> D1 : parsed message
P1 --> P2 : normalized request

P2 --> X2 : triage request
X2 --> P2 : intent/entities/confidence
P2 --> D3 : AI insight
P2 --> P5 : triage result

P5 --> P3 : create/update ticket action
P3 --> X1 : board item API call
X1 --> P3 : ticket id/status
P3 --> D2 : ticket record/mapping
P3 --> P4 : ticket reference + status

P5 --> P4 : communication instruction
P4 --> X3 : outbound email
X3 --> E1 : acknowledgement/updates

P5 --> E2 : escalation task
E2 --> P5 : approval/override

P1 --> D4 : intake audit event
P2 --> D4 : triage audit event
P3 --> D4 : sync audit event
P4 --> D4 : communication audit event
P5 --> D4 : state transition audit event

@enduml